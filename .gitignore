# Project-specific config (generated by /setup)
config/project_config.yaml

# Personal Claude Code settings
.claude/settings.local.json

# Legacy codebase — populate via submodule, symlink, or direct copy
# encoded/legacy/ contents are project-specific and typically large
encoded/legacy/

# Workspace outputs — always disposable
workspaces/*/

# Planning artifacts — non-semantic, cleaned after merge (keep the .gitkeep stub)
artifacts/*/

# Transient output of sync-framework.sh
framework-sync.patch

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo
